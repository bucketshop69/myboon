EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
EXPO_PUBLIC_JUP_API_KEY=
# Set to "testnet" to point Pacific perps at test-api.pacifica.fi (no real funds)
EXPO_PUBLIC_PACIFIC_ENV=mainnet
# Pacific builder code for fee sharing (register at pacifica.fi)
EXPO_PUBLIC_PACIFIC_BUILDER_CODE=MYB00N

# Turnkey (embedded Polygon wallet for Polymarket)
EXPO_PUBLIC_TURNKEY_ORG_ID=
EXPO_PUBLIC_TURNKEY_AUTH_PROXY_CONFIG_ID=

# Predict E2E local-only overrides.
# Put real test-wallet values in apps/hybrid-expo/.env.e2e.local, not here.
PREDICT_E2E_POLYMARKET_PRIVATE_KEY=
# Optional: only needed if you want the mocked suite to use an existing deposit-wallet address
# instead of the locally derived Polygon EOA fallback.
PREDICT_E2E_DEPOSIT_WALLET_ADDRESS=
EXPO_PUBLIC_PREDICT_E2E_SOLANA_ADDRESS=
EXPO_PUBLIC_PREDICT_E2E_POLYGON_ADDRESS=
EXPO_PUBLIC_PREDICT_E2E_DEPOSIT_WALLET_ADDRESS=
