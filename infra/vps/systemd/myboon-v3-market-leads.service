[Unit]
Description=MYBOON V3 Hyperliquid Market Lead Collector
After=network.target

[Service]
Type=oneshot
WorkingDirectory=/opt/myboon/packages/collectors
ExecStart=/usr/bin/flock -n -E 0 /tmp/myboon-v3-market-leads.lock /usr/bin/env pnpm hyperliquid:research-leads
Environment=NODE_ENV=production
Environment=HYPERLIQUID_COLLECTION_LEADS_WRITE=0
Environment=V3_LOCAL_DATA_DIR=/var/lib/myboon/v3
