{
  "name": "@pnldotfun/brain",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "brain:start": "pnpm run build && node dist/run.js",
    "demo:replay": "pnpm run build && node dist/demo-replay.js",
    "research:smoke": "pnpm run build && node dist/research-smoke.js",
    "narrative:analyst": "tsx src/narrative-analyst.ts",
    "test": "echo \"No tests configured\""
  },
  "dependencies": {
    "@pnldotfun/entity-memory": "workspace:*",
    "@pnldotfun/shared": "workspace:*",
    "@pnldotfun/tx-parser": "workspace:*",
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
