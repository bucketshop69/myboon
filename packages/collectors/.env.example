SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional tuning
ODDS_SHIFT_THRESHOLD=0.05

# Polymarket data collector
POLYMARKET_MARKETS_RUN_ONCE=1
POLYMARKET_MARKETS_PREVIEW_ONLY=0
POLYMARKET_MARKETS_RUN_INTERVAL_MS=7200000
POLYMARKET_MARKETS_TAGS=crypto,politics,geopolitics,economics,finance,business,technology,artificial-intelligence,commodities
POLYMARKET_MARKETS_TOP_PER_TAG=10
POLYMARKET_MARKETS_FETCH_LIMIT_PER_TAG=50
POLYMARKET_MARKETS_INCLUDE_MANUAL_PINS=1
POLYMARKET_MARKETS_ODDS_MOVE_THRESHOLD=0.05
POLYMARKET_MARKETS_VOLUME_MOVE_THRESHOLD_PCT=0.2
POLYMARKET_MARKETS_ACTIVITY_SPIKE_THRESHOLD_PCT=0.25
POLYMARKET_MARKETS_CLOSING_SOON_HOURS=72
POLYMARKET_MARKETS_CANDIDATE_COOLDOWN_HOURS=6

# Polymarket researcher
# Requires `hermes`, `python3.12`, and last30days.py.
# Default local path: ~/.codex/skills/last30days/scripts/last30days.py
# Default root/VPS path: /root/.agents/skills/last30days/scripts/last30days.py

# Read-only VPS preflight
POLYMARKET_DOCTOR_SLUG=will-the-fed-increase-interest-rates-by-25-bps-after-the-july-2026-meeting

# Generic publisher from editor_drafts to published_narratives
PUBLISHER_RUN_ONCE=0
PUBLISHER_INTERVAL_MS=300000
PUBLISHER_BATCH_SIZE=10
PUBLISHER_PREVIEW_ONLY=0
