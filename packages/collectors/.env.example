SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional tuning
ODDS_SHIFT_THRESHOLD=0.05

# V3 collection lead persistence.
# This writes collector outputs to collection_runs and collection_leads only.
# It does not write published_narratives.
HYPERLIQUID_COLLECTION_LEADS_WRITE=0

# V3 Hyperliquid lead collection defaults
HYPERLIQUID_RESEARCH_LEAD_MAX_ASSETS=20
HYPERLIQUID_RESEARCH_LEAD_WINDOWS=7,30
HYPERLIQUID_WALLET_BEHAVIOR_DAYS=7

# Local-first V3 handoff. On VPS, point both collector and brain at the same dir.
# Collector writes collection lead JSON under $V3_LOCAL_DATA_DIR/collection-leads/pending.
# Researcher writes packets/books/notes under the same root.
V3_LOCAL_DATA_DIR=
V3_RESEARCH_SEARCH_PROVIDER=disabled
V3_RESEARCH_SEARXNG_URL=
